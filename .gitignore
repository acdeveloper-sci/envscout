# =============================================================================
# envscout — .gitignore
# Based on Python gitignore template, adapted for this project
# =============================================================================

# -----------------------------------------------------------------------------
# Python bytecode and cache
# -----------------------------------------------------------------------------
__pycache__/
*.py[codz]
*$py.class
*.so

# -----------------------------------------------------------------------------
# Distribution / packaging
# -----------------------------------------------------------------------------
.Python
build/
dist/
downloads/
eggs/
.eggs/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
wheels/
share/python-wheels/
sdist/

# -----------------------------------------------------------------------------
# uv (project uses uv for package management)
# uv.lock IS committed — ensures reproducibility for a CLI tool
# -----------------------------------------------------------------------------
.uv-cache/

# -----------------------------------------------------------------------------
# Virtual environments
# (envscout scans for these — keep them out of the repo itself)
# -----------------------------------------------------------------------------
.venv
.venv*/
venv/
venv*/
env/
ENV/

# -----------------------------------------------------------------------------
# Testing and coverage
# -----------------------------------------------------------------------------
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
*.py.cover
.pytest_cache/
.hypothesis/
test_outputs/

# NOTE: .tox/ and .nox/ omitted intentionally —
# tox/nox are detected venv types in envscout; their presence is
# meaningful in the project root if added later for multi-env testing.
# Add back if tox/nox are introduced:
# .tox/
# .nox/

# -----------------------------------------------------------------------------
# Type checking
# -----------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# -----------------------------------------------------------------------------
# Linting
# -----------------------------------------------------------------------------
.ruff_cache/

# -----------------------------------------------------------------------------
# Profiling output (generated by --profile flag)
# -----------------------------------------------------------------------------
*.prof

# -----------------------------------------------------------------------------
# Environment / secrets
# -----------------------------------------------------------------------------
.env
.envrc
.env.*
!.env.example

# -----------------------------------------------------------------------------
# PyPI / publishing
# -----------------------------------------------------------------------------
.pypirc

# -----------------------------------------------------------------------------
# IDE and editors
# Keep .vscode/ and .idea/ optional — team members decide individually
# via their global gitignore. Uncomment to enforce project-wide:
# .vscode/
# .idea/
# -----------------------------------------------------------------------------
.spyderproject
.spyproject
.ropeproject
tempCodeRunnerFile.py

# -----------------------------------------------------------------------------
# Documentation build
# -----------------------------------------------------------------------------
docs/_build/
/site

# -----------------------------------------------------------------------------
# OS generated
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log

# -----------------------------------------------------------------------------
# Cython
# -----------------------------------------------------------------------------
cython_debug/

# -----------------------------------------------------------------------------
# Tools not used in this project (kept as reference, commented out)
# -----------------------------------------------------------------------------
# .pdm-python         # pdm — not used
# .pdm-build/         # pdm — not used
# .pixi               # pixi — not used
# __pypackages__/     # PEP 582 — not used
# .ipynb_checkpoints  # Jupyter — not used
# .abstra/            # Abstra — not used
# .streamlit/         # Streamlit — not used
# marimo/             # Marimo — not used
